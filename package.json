{
  "name": "agent-forge",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"npm -w server run dev\" \"npm -w client run dev\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w client run build && npm -w server run build",
    "build:server": "npm -w server run build",
    "build:client": "npm -w client run build",
    "start": "npm -w server run start"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
